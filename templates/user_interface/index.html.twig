    {% include 'partie/navbar.html.twig' %}
    <div class="table">
    <table class="table table-hover table-striped table-bordered text-center">
        <thead class="table-dark">
        <tr>
            <th scope="col">Nom</th>
            <th scope="col">Prénom</th>
            <th scope="col">Sexe</th>
            <th scope="col">Email</th>
            <th scope="col">Poste</th>
            <th scope="col">CIN</th>
            <th scope="col">Téléphone</th>
            <th scope="col">Adresse</th>
            <th colspan="2">
                <a href="{{ path('app_user_add') }}" class="btn btn-primary">Ajouter un user</a>
            </th>
        </tr>
        </thead>
        <tbody>
        {% for elem in users %}
        <tr>
            <td>{{ elem.nom }}</td>
            <td>{{ elem.prenom }}</td>
            <td>{{ elem.sexe }}</td>
            <td>{{ elem.email }}</td>
            <td>{{ elem.poste }}</td>
            <td>{{ elem.cin }}</td>
            <td>0{{ elem.telephone }}</td>
            <td>{{ elem.adresse }}</td>

            <td>
                <a href="{{ path('update_user', {id: elem.id}) }}" class="btn1 btn-warning btn-sm">Modifier</a>
            </td>
            <td>
                <a href="{{ path('delete_user', {id: elem.id}) }}" class="btn1 btn-danger btn-sm">Supprimer</a>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    </div>
