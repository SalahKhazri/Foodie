        /* Conteneur de la table */
        .table {
            width: 90%;
            margin: 20px auto;
            background: white;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        /* Table styling */
        .table table {
            width: 100%;
            border-collapse: collapse;
        }

        /* En-tête de la table */
        .table thead {
            background: #f9f6ee; /* Marron doux */
            color: black;
        }

        /* Style des cellules d'en-tête */
        .table th {
            padding: 15px;
            font-size: 16px;
        }

        /* Style des cellules */
        .table td {
            padding: 12px;
            font-size: 15px;
            border-bottom: 1px solid #ddd;
        }

        /* Effet alterné sur les lignes */
        .table tbody tr:nth-child(even) {
            background: #f9f6ee; /* Beige clair */
        }

        /* Effet au survol */
        .table tbody tr:hover {
            background: #e3dac9; /* Crème doux */
        }

        /* Boutons */
        .btn1 {
            padding: 8px 12px;
            border-radius: 5px;
            font-size: 14px;
            font-weight: bold;
            text-decoration: none;
            display: inline-block;
            text-align: center;
            transition: 0.3s;
        }

        /* Bouton Ajouter */
        .btn-primary {
            background: #b05e3d; /* Terracotta */
            color: white;
            padding: 10px 15px;
            font-size: 16px;
            border-radius: 5px;
        }

        .btn-primary:hover {
            background: #8c5a42;
        }

        /* Bouton Modifier */
        .btn-warning {
            background: #e3a24f; /* Orangé doux */
            color: white;
        }

        .btn-warning:hover {
            background: #c4883b;
        }

        /* Bouton Supprimer */
        .btn-danger {
            background: #d9534f; /* Rouge doux */
            color: white;
        }

        .btn-danger:hover {
            background: #c12e2a;
        }

    </style>

