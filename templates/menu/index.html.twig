{% extends 'base.html.twig' %}

{% block title %}Hello AdminInterfaceController!{% endblock %}

{% block body %}
    <style>


        .btn {
            background-color: #13ba13;
            color: black;
            border: none;
            padding: 8px 15px;
            margin-right: 10px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 16px;
        }

        .btn:hover {
            background-color: #13ba13;
            color: black;
        }

        .table {
            border-radius: 8px;
            box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            background-color: #FFFFFF;
        }

        /* Changer la couleur des lignes au survol */
        .table-hover tbody tr:hover {
            background-color: #eee;
            transition: 0.3s;
        }

        /* Espacer les colonnes */
        th, td {
            padding: 12px;
            vertical-align: middle;
        }

        /* Personnaliser le bouton "Ajouter un user" */
        .btn-primary {
            background-color: #007bff;
            border: none;
            transition: 0.3s;
        }

        .btn-primary:hover {
            background-color: #0056b3;
        }

        /* Personnaliser les boutons Modifier et Supprimer */
        .btn-warning {
            color: #fff;
            background-color: #ffc107;
            border: none;
        }

        .btn-danger {
            color: #fff;
            background-color: #dc3545;
            border: none;
        }

    </style>



    {% include 'partie/navbar.html.twig' %}
    <table class="table table-hover table-striped table-bordered text-center">
        <thead class="table-dark">
        <tr>
            <th scope="col">Nom</th>
            <th scope="col">Description</th>
            <th scope="col">Type de plat</th>
            <th scope="col">Statut</th>
            <th scope="col">Prix</th>
            <th scope="col">Image</th>

            <th colspan="2">
                <a href="{{ path('add_menu') }}" class="btn btn-primary">Ajouter un Menu</a>
            </th>
        </tr>
        </thead>
        <tbody>
        {% for elem in menus %}
            <tr>
                <td>{{ elem.nom }}</td>
                <td>{{ elem.description }}</td>
                <td>{{ elem.typeDePlat }}</td>
                <td>{{ elem.statut }}</td>
                <td>{{ elem.prix }}</td>
                <td>
                    {% if elem.image %}
                        <img src="{{ elem.base64Image }}" width="100" height="100">
                    {% else %}
                        Pas d'image
                    {% endif %}
                </td>


                <td>
                    <a href="{{ path('page_edit', {id: elem.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
                </td>
                <td>
                    <a href="{{ path('menu_delete', {id: elem.id}) }}" class="btn btn-danger btn-sm">Supprimer</a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

{% endblock %}

